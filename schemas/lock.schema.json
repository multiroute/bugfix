{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bugfix.local/schemas/lock.json",
  "title": "bugfix per-ticket lock",
  "type": "object",
  "additionalProperties": false,
  "required": ["pid", "session_id", "stage", "acquired_at"],
  "properties": {
    "pid":          { "type": "integer", "minimum": 1 },
    "session_id":   { "type": "string", "minLength": 1 },
    "stage": {
      "type": "string",
      "enum": ["intake", "planning", "executing", "finishing", "ci-watching", "pr-reviewing"]
    },
    "acquired_at":  { "type": "string", "format": "date-time" }
  }
}
