{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bugfix.local/schemas/events.json",
  "title": "bugfix event log entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["t", "event", "stage"],
  "properties": {
    "t":     { "type": "string", "format": "date-time" },
    "event": {
      "type": "string",
      "enum": [
        "intake_started", "intake_passed", "intake_blocked",
        "worktree_created", "worktree_reused",
        "plan_reviewed", "plan_revised",
        "task_started", "task_spec_review_failed", "task_code_quality_review_failed", "task_done",
        "pr_pushed", "pr_opened",
        "ci_failed", "ci_green", "ci_fix_attempted",
        "pr_rebased", "pr_review_started", "pr_review_blocked", "pr_merge_ready", "pr_closed",
        "block_and_comment", "resumed"
      ]
    },
    "stage": {
      "type": "string",
      "enum": ["intake", "planning", "executing", "finishing", "ci-watching", "pr-reviewing"]
    },
    "detail": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "description": "When event is block_and_comment, detail.exit_kind MUST be one of the documented enum values. Catches drift between stage skills and the block-and-comment contract.",
      "if": {
        "properties": { "event": { "const": "block_and_comment" } },
        "required": ["event"]
      },
      "then": {
        "properties": {
          "detail": {
            "type": "object",
            "required": ["exit_kind"],
            "properties": {
              "exit_kind": {
                "type": "string",
                "enum": ["needs-info", "rejected", "tech-failure"]
              }
            }
          }
        },
        "required": ["detail"]
      }
    }
  ]
}
