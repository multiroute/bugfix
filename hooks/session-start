#!/usr/bin/env bash
# SessionStart hook for bugfix plugin.
# Reads skills/using-bugfix/SKILL.md, wraps it in <EXTREMELY_IMPORTANT> tags,
# emits as additionalContext in JSON shaped for Claude Code.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

skill_path="${PLUGIN_ROOT}/skills/using-bugfix/SKILL.md"
if [[ ! -f "$skill_path" ]]; then
  # Fail fast so Claude Code surfaces a real hook error instead of injecting
  # a banner that says "you have access to bugfix skills" wrapped around an
  # error message body. A silently-broken plugin is worse than a loudly-broken one.
  echo "bugfix:session-start: using-bugfix SKILL.md not found at $skill_path" >&2
  exit 1
fi

# Build the whole JSON envelope in Python. The skill body is read from a file
# whose path we pass via an env var, then assembled and JSON-encoded in one
# pass. Crucially, we never interpolate untrusted content into a shell heredoc:
# the previous design used an unquoted heredoc that would have evaluated any
# $(...) or backtick in the skill body as a shell command.
SKILL_PATH="$skill_path" python3 <<'PYTHON'
import json, os, sys
with open(os.environ["SKILL_PATH"], "r", encoding="utf-8") as fh:
    skill_body = fh.read()
wrapped = (
    "<EXTREMELY_IMPORTANT>\n"
    "You have access to the bugfix plugin's skills.\n\n"
    f"{skill_body}\n"
    "</EXTREMELY_IMPORTANT>"
)
envelope = {"hookSpecificOutput": {"additionalContext": wrapped}}
sys.stdout.write(json.dumps(envelope))
sys.stdout.write("\n")
PYTHON
